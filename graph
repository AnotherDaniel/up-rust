"UPSTREAM.ECLIPSE.ECLIPSE-CODE_REVIEW" [label="UPSTREAM.ECLIPSE.ECLIPSE-CODE_REVIEW:\nAny changes to an Eclipse projects\nalways go through review, and are\nonly merged on approval. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-COMMIT_RECORDS" [label="UPSTREAM.ECLIPSE.ECLIPSE-COMMIT_RECORDS:\nEclipse project commit records have\na consistent form, include the author\nand should reference the issue that\nthey are addressing. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-CONSTRUCTIVE_CULTURE" [label="UPSTREAM.ECLIPSE.ECLIPSE-CONSTRUCTIVE_CULTURE:\nAn Eclipse project handles bug reports,\ndiscussions and decisions in a healthy,\nconstructive and welcoming manner,\nand that issues raised against the\nproject are addressed in a timely\nmanner. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-CONTRIBUTION_PROCESS" [label="UPSTREAM.ECLIPSE.ECLIPSE-CONTRIBUTION_PROCESS:\nThe contribution process for an Eclipse\nproject is publicly documented and\nconsistently followed. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-FORMAL_RELEASES" [label="UPSTREAM.ECLIPSE.ECLIPSE-FORMAL_RELEASES:\nEach release of an Eclipse project\nundergoes formal review and approval.\n", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-IP_COMPLIANCE" [label="UPSTREAM.ECLIPSE.ECLIPSE-IP_COMPLIANCE:\nAn Eclipse project follows the [Eclipse\nFoundation IP Policy](https://www.eclipse.org/org/documents/Eclipse_IP_Policy.pdf)\nat all times. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-METADATA_CORRECTNESS" [label="UPSTREAM.ECLIPSE.ECLIPSE-METADATA_CORRECTNESS:\nTechnical metadata of an Eclipse\nproject is always correct and up\nto date. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-PROCESSES" [label="UPSTREAM.ECLIPSE.ECLIPSE-PROCESSES:\nAll Eclipse projects follow the Eclipse\nFoundation Development Process. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-PROJECT_README" [label="UPSTREAM.ECLIPSE.ECLIPSE-PROJECT_README:\nAn Eclipse projects must have a README\nfile with information about the project.\n", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-PROJECT_SCOPE" [label="UPSTREAM.ECLIPSE.ECLIPSE-PROJECT_SCOPE:\nAn Eclipse project's scope and objectives\nare formally documented and maintained.\n", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-PUBLIC_CODE" [label="UPSTREAM.ECLIPSE.ECLIPSE-PUBLIC_CODE:\nAll source code of an Eclipse project\nis kept and maintained via Eclipse-managed\ninfrastructure. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-PUBLIC_RECORDS" [label="UPSTREAM.ECLIPSE.ECLIPSE-PUBLIC_RECORDS:\nAll tickets, issue discussions, bug\nreports and decisions of an Eclipse\nproject are kept and made publicly\naccessibly via Eclipse-managed infrastructure.\n", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-SBOM_GENERATION" [label="UPSTREAM.ECLIPSE.ECLIPSE-SBOM_GENERATION:\nAn Eclipse projects generates Software\nBill of Materials (SBOM) documentation\nfor the software that is produced.\nThis is optional for libraries, but\nmandatory for applications or standalone\ncomponents. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-SECURITY_POLICY" [label="UPSTREAM.ECLIPSE.ECLIPSE-SECURITY_POLICY:\nAn Eclipse project defines a process\nfor handling, analysis and resolution\nof security issues that are reported.\n", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-SECURITY_REPORTING" [label="UPSTREAM.ECLIPSE.ECLIPSE-SECURITY_REPORTING:\nAn Eclipse project provides information\nabout how and where to report security\nissues. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-VERSION_CONTROL" [label="UPSTREAM.ECLIPSE.ECLIPSE-VERSION_CONTROL:\nAll changes to an Eclipse project\nare tracked through version control\nwith full attribution. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.ECLIPSE.ECLIPSE-VULNERABILITY_MANAGEMENT" [label="UPSTREAM.ECLIPSE.ECLIPSE-VULNERABILITY_MANAGEMENT:\nAn Eclipse project follows obligations\nand practices regarding the analysis\nand reporting and disclosure of vulnerabilities.\n", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.RUST.RUST-CVE_MANAGEMENT" [label="UPSTREAM.RUST.RUST-CVE_MANAGEMENT:\nProject is actively managing known/reported\nCVEs in its supply chain e.g. by\nusing `cargo deny`. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.RUST.RUST-FORMATTER" [label="UPSTREAM.RUST.RUST-FORMATTER: Project\nis using `cargo fmt` to reject merging\nof any code that fails the standard\nRust formatting rules. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.RUST.RUST-LINTER" [label="UPSTREAM.RUST.RUST-LINTER: Project\nis using `cargo clippy`, treating\nall warning as errors, to vet pull\nrequest and reject merging of any\ncode that fails the linter. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.RUST.RUST-TEST_HARNESS" [label="UPSTREAM.RUST.RUST-TEST_HARNESS:\nProject is using Rust test tooling\nand core framework runners. Any additional\ntest harnesses and approaches are\nintegrated with the core test setup\nand are run in the same (automated)\nmanner. ", URL="", target="_top", shape=box, fontname="Open Sans"];
"UPSTREAM.RUST.RUST-VERSION" [label="UPSTREAM.RUST.RUST-VERSION: Project\nis actively managing its Minimum\nSupported Rust Version (MSRV). ", URL="", target="_top", shape=box, fontname="Open Sans"];
